# MailGuard OSS — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to source control

# ── Supabase ─────────────────────────────────────────────────────────────────
# Always use SERVICE ROLE KEY — never the anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis (Upstash TLS) ───────────────────────────────────────────────────────
# Must start with rediss:// (TLS)
REDIS_URL=rediss://default:your-token@your-host.upstash.io:6379

# ── Encryption ───────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hex chars = 32 bytes (AES-256)
ENCRYPTION_KEY=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
# Must be at least 64 characters
JWT_SECRET=
JWT_EXPIRY_MINUTES=10

# ── Magic Links ───────────────────────────────────────────────────────────────
MAGIC_LINK_EXPIRY_MINUTES=15

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
# Your Telegram user ID (integer) — get from @userinfobot
TELEGRAM_ADMIN_UID=123456789

# ── App ───────────────────────────────────────────────────────────────────────
# 'production' or 'development' (development enables /docs)
ENV=production
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, e.g. https://app.example.com
# Never use * in production
ALLOWED_ORIGINS=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the deployed frontend dashboard.
# Added automatically to ALLOWED_ORIGINS so the browser can reach the API.
# Example: https://dashboard.yourdomain.com
# Leave empty if no separate frontend is deployed.
FRONTEND_URL=

# Local development: port the frontend container listens on (docker-compose only)
FRONTEND_PORT=8080

# ── Internal ─────────────────────────────────────────────────────────────────
# Internal API base URL for worker→api calls (leave empty if not used)
INTERNAL_API_URL=

# ── Magic Link Base URL ───────────────────────────────────────────────────────
# Public base URL used when constructing magic link verify URLs in emails.
# Required when the API runs behind a reverse proxy or in a container.
# Example: https://api.yourdomain.com
# Leave empty to use the incoming request base URL (local development only)
MAGIC_LINK_BASE_URL=

# ── Sender Rotation ───────────────────────────────────────────────────────────
# Rotate to next sender when daily usage reaches this fraction (0.0–1.0)
ROTATION_THRESHOLD=0.80
